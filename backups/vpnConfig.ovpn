dev tun
persist-tun
persist-key
data-ciphers AES-256-GCM:AES-128-GCM:CHACHA20-POLY1305:AES-256-CBC
data-ciphers-fallback AES-256-CBC
auth SHA256
tls-client
client
resolv-retry infinite
remote <IP> 1194 udp4
nobind
verify-x509-name "vpn_server" name
auth-user-pass
remote-cert-tls server
explicit-exit-notify

